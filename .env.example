# Application
NODE_ENV=development
PORT=3000
WEB_ORIGIN=http://localhost:4200
WEB_APP_URL=http://localhost:4200
WEB_SESSION_COOKIE=ozon_web_session
WEB_SESSION_TTL_DAYS=30
WEB_MAGIC_LINK_TTL_MINUTES=20
RESEND_API_KEY=
EMAIL_FROM=no-reply@example.com

# Telegram bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ADMIN_IDS=
WEBHOOK_DOMAIN=https://example.com
WEBHOOK_PATH=/telegram

# Ozon API
OZON_CLIENT_ID=your-client-id
OZON_API_KEY=your-api-key
OZON_API_BASE_URL=https://api-seller.ozon.ru

# Ozon supply automation
OZON_SUPPLY_SPREADSHEET_ID=your-google-sheet-id
OZON_SUPPLY_DROP_OFF_ID=23953262807000
OZON_SUPPLY_POLL_INTERVAL_MS=3000

# Database
DATABASE_PATH=data/bot.sqlite
DATABASE_LOGGING=false

# HTTP client tuning (опционально)
HTTP_TIMEOUT_MS=10000
HTTP_RETRY_ATTEMPTS=10000
HTTP_RETRY_BASE_MS=200
